---
const currentYear = new Date().getFullYear();

const footerLinks = {
  services: [
    { label: 'Pole Barn Building', href: '/services/pole-barns' },
    { label: 'Roofing Services', href: '/services/roofing' },
    { label: 'Fence Building', href: '/services/fences' },
    { label: 'Land Grading', href: '/services/grading' },
  ],
  company: [
    { label: 'About Us', href: '/about' },
    { label: 'Contact', href: '/contact' },
    { label: 'Get a Quote', href: '/contact' },
  ],
};
---

<footer class="bg-red-900 text-gold-100 border-t-4 border-gold-400">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Brand & Contact -->
      <div>
        <h3 class="text-gold-400 text-lg font-bold mb-4">CTH Contracting Solutions</h3>
        <p class="mb-4">Quality construction services you can trust. Licensed, insured, and built to last.</p>
        <div class="space-y-2">
          <p>
            <a href="tel:+15551234567" class="hover:text-gold-400 transition-colors">
              📞 (555) 123-4567
            </a>
          </p>
          <p>
            <a href="mailto:info@cthcontractingsolutions.com" class="hover:text-gold-400 transition-colors">
              ✉️ info@cthcontractingsolutions.com
            </a>
          </p>
          <p>📍 Georgia, USA</p>
        </div>
      </div>
      
      <!-- Services -->
      <div>
        <h4 class="text-gold-400 font-semibold mb-4">Our Services</h4>
        <ul class="space-y-2">
          {footerLinks.services.map(link => (
            <li>
              <a href={link.href} class="hover:text-gold-400 transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
      
      <!-- Company -->
      <div>
        <h4 class="text-gold-400 font-semibold mb-4">Company</h4>
        <ul class="space-y-2">
          {footerLinks.company.map(link => (
            <li>
              <a href={link.href} class="hover:text-gold-400 transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
        <div class="mt-6">
          <a href="/contact" class="btn-primary">
            Get Free Quote
          </a>
        </div>
      </div>
    </div>
    
    <!-- Bottom bar -->
    <div class="border-t border-red-800 mt-12 pt-8 flex flex-col md:flex-row justify-between items-center">
      <p class="text-sm">© {currentYear} CTH Contracting Solutions. All rights reserved.</p>
      <p class="text-sm mt-2 md:mt-0">Licensed & Insured Contractor</p>
    </div>
  </div>
</footer>
