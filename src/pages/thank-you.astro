---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const pageTitle = "Thank You | CTH Contracting Solutions";
const pageDesc = "Thank you for contacting CTH Contracting Solutions. We'll be in touch soon with your free estimate.";
---

<Layout title={pageTitle} description={pageDesc} canonical="/thank-you">
  <Header />
  
  <section class="min-h-screen flex items-center justify-center py-20 bg-neutral-900">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <div class="text-6xl mb-6">✅</div>
      <h1 class="text-4xl md:text-5xl font-black text-white mb-4 uppercase tracking-wide">Thank You!</h1>
      <p class="text-xl text-gold-400 mb-6">Your message has been received.</p>
      <p class="text-neutral-400 mb-8">
        We'll review your project details and get back to you within 24 hours with your free estimate.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="bg-orange-600 hover:bg-orange-500 text-white font-black py-4 px-10 rounded transition-all duration-300 uppercase tracking-wider">
          Back to Home
        </a>
        <a href="/services" class="border-2 border-white text-white font-black py-4 px-10 rounded hover:bg-white hover:text-black transition-all duration-300 uppercase tracking-wider">
          View Services
        </a>
      </div>
    </div>
  </section>
  
  <Footer />
</Layout>
