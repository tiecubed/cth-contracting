---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const pageTitle = "Pole Barn Builders Georgia | Custom Post-Frame Buildings | CTH";
const pageDesc = "Expert pole barn builders in Georgia. Custom post-frame buildings for agricultural, workshop, garage & storage. Free estimates. Licensed & insured contractor.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Pole Barn Building Services",
  "provider": {
    "@type": "LocalBusiness",
    "name": "CTH Contracting Solutions",
    "areaServed": "Georgia"
  },
  "serviceType": "Pole Barn Construction",
  "description": pageDesc
};

const benefits = [
  { title: "Fast Construction", desc: "Post-frame buildings go up quickly" },
  { title: "Cost Effective", desc: "Less expensive than traditional methods" },
  { title: "Durable & Strong", desc: "Built for Georgia weather" },
  { title: "Versatile Design", desc: "Customize to your needs" },
];
---

<Layout title={pageTitle} description={pageDesc} canonical="/services/pole-barns" jsonLd={jsonLd}>
  <Header />
  
  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-red-900 via-red-800 to-red-700 text-white py-16 border-b-4 border-gold-400">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <div class="text-5xl mb-4">🏗️</div>
        <h1 class="text-4xl md:text-5xl font-bold mb-4 text-shadow-lg">
          Georgia's Pole Barn Experts
        </h1>
        <p class="text-xl text-gold-100 mb-6">
          Custom post-frame buildings engineered for your needs. Agricultural barns, workshops, 
          garages, and more—built to last.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/contact" class="btn-primary">Get Free Quote</a>
          <a href="tel:15551234567" class="btn-secondary">Call (555) 123-4567</a>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Benefits -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-red-900 text-center mb-12">Why Choose a Post-Frame Building?</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        {benefits.map(benefit => (
          <div class="bg-gold-50 p-6 rounded-xl border-2 border-gold-200">
            <h3 class="text-lg font-bold text-red-900 mb-2">{benefit.title}</h3>
            <p class="text-red-800">{benefit.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  
  <!-- CTA -->
  <section class="bg-red-700 text-white py-16 border-y-4 border-gold-400">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold mb-4">Ready to Build Your Pole Barn?</h2>
      <p class="text-xl text-gold-100 mb-8">Get a free, no-obligation estimate.</p>
      <a href="/contact" class="btn-primary">Request Free Estimate</a>
    </div>
  </section>
  
  <Footer />
</Layout>
