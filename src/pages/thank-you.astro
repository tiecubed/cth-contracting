---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const pageTitle = "Thank You | CTH Contracting Solutions";
const pageDesc = "Thank you for contacting CTH Contracting Solutions. We'll be in touch within 24 hours.";
---

<Layout title={pageTitle} description={pageDesc}>
  <Header />
  
  <section class="py-24 text-center">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-6xl mb-6">✅</div>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
        Thank You!
      </h1>
      <p class="text-xl text-gray-600 mb-8">
        Your request has been received. A member of our team will contact you 
        within 24 hours to discuss your project.
      </p>
      
      <div class="bg-gray-50 rounded-xl p-8 mb-8">
        <h2 class="text-lg font-semibold text-gray-900 mb-2">What happens next?</h2>
        <ul class="text-gray-600 space-y-2">
          <li>📞 We'll call you to discuss your project details</li>
          <li>📋 We'll prepare a free, detailed estimate</li>
          <li>🤝 We'll schedule a site visit if needed</li>
        </ul>
      </div>
      
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href="/" class="btn-primary">
          Return Home
        </a>
        <a href="/services" class="btn-secondary">
          Explore Services
        </a>
      </div>
      
      <p class="mt-8 text-gray-500">
        Need immediate assistance? Call us at 
        <a href="tel:15551234567" class="text-brand-600 font-semibold">(555) 123-4567</a>
      </p>
    </div>
  </section>
  
  <Footer />
</Layout>
