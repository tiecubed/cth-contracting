---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const pageTitle = "Contact Us | Free Estimates | CTH Contracting Solutions";
const pageDesc = "Get a free estimate for pole barns, roofing, fencing, and grading services in Greenville SC, Anderson SC and surrounding areas. Call or text 864-617-1719.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Contact CTH Contracting Solutions",
  "description": pageDesc,
  "url": "https://cthcontractingsolutions.com/contact"
};
---

<Layout title={pageTitle} description={pageDesc} canonical="/contact" jsonLd={jsonLd}>
  <Header />
  
  <!-- Hero -->
  <section class="bg-gradient-to-r from-red-900 to-red-800 text-white py-20 border-b-4 border-gold-400">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-black mb-4 uppercase tracking-wide">Get Your Free Estimate</h1>
      <p class="text-xl text-gold-200 max-w-3xl mx-auto">
        Ready to start your project? Contact us today for a free, no-obligation quote.
      </p>
    </div>
  </section>
  
  <!-- Contact Section -->
  <section class="py-20 bg-neutral-900">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Simple Contact Form -->
      <div class="bg-neutral-800 p-8 md:p-12 rounded-2xl shadow-lg border border-neutral-700 text-center">
        <h2 class="text-2xl font-bold text-white mb-2">Request a Call Back</h2>
        <p class="text-neutral-400 mb-8">Enter your info and we'll contact you within 24 hours.</p>
        
        <form name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/thank-you" class="space-y-6">
          <input type="hidden" name="form-name" value="contact" />
          <p class="hidden"><label>Don't fill this out: <input name="bot-field" /></label></p>
          
          <div class="grid md:grid-cols-2 gap-4">
            <div>
              <label for="name" class="block text-sm font-medium text-neutral-300 mb-1 text-left">Name *</label>
              <input type="text" id="name" name="name" required
                class="w-full px-4 py-3 bg-neutral-700 border border-neutral-600 rounded-lg focus:ring-2 focus:ring-gold-400 focus:border-gold-400 outline-none text-white text-lg" 
                placeholder="Your name" />
            </div>
            <div>
              <label for="phone" class="block text-sm font-medium text-neutral-300 mb-1 text-left">Phone Number *</label>
              <input type="tel" id="phone" name="phone" required
                class="w-full px-4 py-3 bg-neutral-700 border border-neutral-600 rounded-lg focus:ring-2 focus:ring-gold-400 focus:border-gold-400 outline-none text-white text-lg" 
                placeholder="(864) 617-1719" />
            </div>
          </div>
          
          <button type="submit" class="w-full bg-orange-600 hover:bg-orange-500 text-white font-black py-4 rounded transition-all duration-300 uppercase tracking-wider text-lg shadow-lg hover:shadow-xl hover:-translate-y-1">
            Request Call Back
          </button>
        </form>
        
        <!-- Alternative Contact -->
        <div class="mt-8 pt-8 border-t border-neutral-700">
          <p class="text-gold-400 text-lg mb-2">Or you can call or text us now</p>
          <a href="tel:8646171719" class="text-3xl md:text-4xl font-black text-white hover:text-gold-400 transition-colors">
            (864) 617-1719
          </a>
          <p class="text-neutral-500 mt-2">We typically respond within minutes during business hours</p>
        </div>
      </div>
      
      <!-- Contact Info -->
      <div class="mt-12 grid md:grid-cols-2 gap-8">
        <div class="text-center md:text-left">
          <h3 class="text-xl font-bold text-white mb-4">Service Areas</h3>
          <p class="text-neutral-400">
            Greenville, SC<br>
            Anderson, SC<br>
            and surrounding areas
          </p>
        </div>
        <div class="text-center md:text-right">
          <h3 class="text-xl font-bold text-white mb-4">Business Hours</h3>
          <p class="text-neutral-400">
            Mon-Fri: 7AM-6PM<br>
            Sat: 8AM-2PM<br>
            Sun: Closed
          </p>
        </div>
      </div>
    </div>
  </section>
  
  <Footer />
</Layout>
