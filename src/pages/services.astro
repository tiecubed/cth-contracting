---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const pageTitle = "Construction Services | Pole Barns, Roofing, Fencing & Grading | CTH";
const pageDesc = "Full-service contractor in Greenville, SC &amp; Anderson, SC. Pole barns, roofing, fence building & land grading. Free estimates. Licensed & insured.";

const services = [
  {
    title: "Pole Barn Building",
    shortDesc: "Custom post-frame buildings for every need",
    description: "From agricultural barns to workshops, garages, and storage buildings, we design and construct durable pole barns tailored to your specifications. Our post-frame buildings feature quality materials and expert craftsmanship.",
    features: ["Custom designs", "Agricultural buildings", "Workshops & garages", "Storage buildings", "Permit handling"],
    icon: "🏗️",
    href: "/services/pole-barns"
  },
  {
    title: "Roofing Services",
    shortDesc: "Durable roofing that protects for decades",
    description: "Upgrade to a metal roof that stands up to Georgia's weather while adding value to your property. We install standing seam, corrugated, and specialty metal roofing systems with professional results.",
    features: ["Standing seam roofs", "Corrugated metal", "Reroofing services", "Leak repairs", "Energy efficient"],
    icon: "🏠",
    href: "/services/roofing"
  },
  {
    title: "Fence Building",
    shortDesc: "Secure, beautiful fencing for any property",
    description: "Enhance your property's security and curb appeal with professional fence installation. We build wood privacy fences, vinyl fencing, chain link, and ornamental metal fences.",
    features: ["Wood privacy fences", "Vinyl fencing", "Chain link", "Ornamental metal", "Farm & ranch fencing"],
    icon: "🚧",
    href: "/services/fences"
  },
  {
    title: "Land Grading",
    shortDesc: "Professional site preparation",
    description: "Proper grading is essential for any construction project. We provide land leveling, excavation, drainage solutions, and site preparation to ensure your project starts on solid ground.",
    features: ["Site leveling", "Excavation", "Drainage solutions", "Foundation prep", "Erosion control"],
    icon: "🚜",
    href: "/services/grading"
  }
];
---

<Layout title={pageTitle} description={pageDesc} canonical="/services">
  <Header />
  
  <!-- Hero -->
  <section class="bg-gradient-to-r from-red-900 to-red-800 text-white py-20 border-b-4 border-gold-400">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-black mb-4 uppercase tracking-wide">Our Services</h1>
      <p class="text-xl text-gold-200 max-w-3xl mx-auto">
        Professional construction services across Greenville, SC &amp; Anderson, SC. Quality craftsmanship, fair pricing, and dependable results.
      </p>
    </div>
  </section>
  
  <!-- Services List -->
  <section class="py-20 bg-neutral-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-20">
        {services.map((service, index) => (
          <div class={`grid md:grid-cols-2 gap-8 items-center ${index % 2 === 1 ? 'md:flex-row-reverse' : ''}`}>
            <div class={index % 2 === 1 ? 'md:order-2' : ''}>
              <div class="text-5xl mb-4">{service.icon}</div>
              <h2 class="text-3xl font-bold text-white mb-2">{service.title}</h2>
              <p class="text-xl text-gold-400 mb-4">{service.shortDesc}</p>
              <p class="text-neutral-400 mb-6">{service.description}</p>
              <ul class="grid grid-cols-2 gap-2 mb-6">
                {service.features.map(feature => (
                  <li class="flex items-center gap-2 text-neutral-300">
                    <span class="text-gold-400 font-bold">✓</span> {feature}
                  </li>
                ))}
              </ul>
              <a href="/contact" class="inline-block bg-orange-600 hover:bg-orange-500 text-white font-bold py-3 px-8 rounded transition-all duration-300 uppercase tracking-wider">
                Get Quote
              </a>
            </div>
            <div class={`bg-neutral-800 rounded-2xl aspect-[4/3] flex items-center justify-center text-neutral-500 border-4 border-gold-400 ${index % 2 === 1 ? 'md:order-1' : ''}`}>
              <span>{service.title} Photo</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
  
  <!-- CTA -->
  <section class="bg-red-900 text-white py-20 border-y-4 border-gold-400">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-black mb-4 uppercase tracking-wide">Not Sure What You Need?</h2>
      <p class="text-xl text-gold-200 mb-8">
        Contact us for a free consultation. We'll help you determine the best solution for your project.
      </p>
      <a href="/contact" class="inline-block bg-gold-400 hover:bg-gold-300 text-black font-black py-4 px-10 rounded transition-all duration-300 uppercase tracking-wider shadow-lg hover:shadow-xl hover:-translate-y-1">
        Schedule Free Consultation
      </a>
    </div>
  </section>
  
  <Footer />
</Layout>
