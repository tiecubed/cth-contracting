---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const pageTitle = "Pole Barn Builders Georgia | Custom Post-Frame Buildings | CTH";
const pageDesc = "Expert pole barn builders in Georgia. Custom post-frame buildings for agricultural, workshop, garage & storage. Free estimates. Licensed & insured contractor.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Pole Barn Building Services",
  "provider": {
    "@type": "LocalBusiness",
    "name": "CTH Contracting Solutions",
    "areaServed": "Georgia"
  },
  "serviceType": "Pole Barn Construction",
  "description": pageDesc
};

const benefits = [
  { title: "Fast Construction", desc: "Post-frame buildings go up quickly, saving you time and money" },
  { title: "Cost Effective", desc: "Less expensive than traditional construction methods" },
  { title: "Durable & Strong", desc: "Built to withstand Georgia weather for generations" },
  { title: "Versatile Design", desc: "Customize size, doors, windows, and interior layout" },
  { title: "Low Maintenance", desc: "Quality materials mean less upkeep over time" },
  { title: "Energy Efficient", desc: "Proper insulation options for year-round comfort" },
];

const applications = [
  "Agricultural barns & equipment storage",
  "Horse barns & equestrian facilities",
  "Workshops & hobby buildings",
  "Garages & vehicle storage",
  "RV & motorhome covers",
  "Commercial & retail buildings",
  "Warehouses & storage facilities",
  "Residential barndominiums",
];
---

<Layout title={pageTitle} description={pageDesc} canonical="/services/pole-barns" jsonLd={jsonLd}>
  <Header />
  
  <!-- Hero -->
  <section class="bg-gradient-to-r from-brand-800 to-brand-600 text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <div class="text-5xl mb-4">🏗️</div>
        <h1 class="text-4xl md:text-5xl font-bold mb-4">
          Georgia's Pole Barn Experts
        </h1>
        <p class="text-xl text-brand-100 mb-6">
          Custom post-frame buildings engineered for your needs. Agricultural barns, workshops, 
          garages, and more—built to last a lifetime in Georgia's climate.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/contact" class="btn-primary bg-white text-brand-700 hover:bg-gray-100">
            Get Free Quote
          </a>
          <a href="tel:15551234567" class="btn-secondary border-white text-white hover:bg-white/10">
            Call (555) 123-4567
          </a>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Benefits -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 text-center mb-12">
        Why Choose a Post-Frame Building?
      </h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {benefits.map(benefit => (
          <div class="bg-gray-50 p-6 rounded-xl">
            <h3 class="text-lg font-bold text-gray-900 mb-2">{benefit.title}</h3>
            <p class="text-gray-600">{benefit.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  
  <!-- Applications -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold text-gray-900 mb-6">
            Custom Buildings for Every Need
          </h2>
          <p class="text-gray-600 mb-6">
            Whether you need a simple equipment shed or a fully-finished workshop, we design and 
            build post-frame structures tailored to your exact specifications.
          </p>
          <ul class="space-y-3">
            {applications.map(app => (
              <li class="flex items-center gap-3 text-gray-700">
                <span class="text-brand-500 font-bold">✓</span> {app}
              </li>
            ))}
          </ul>
        </div>
        <div class="bg-gray-200 rounded-2xl aspect-[4/3] flex items-center justify-center text-gray-400">
          <span>Pole Barn Gallery</span>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Process -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 text-center mb-12">Our Building Process</h2>
      <div class="grid md:grid-cols-4 gap-8 text-center">
        <div>
          <div class="w-16 h-16 bg-brand-100 rounded-full flex items-center justify-center text-2xl font-bold text-brand-700 mx-auto mb-4">1</div>
          <h3 class="font-bold text-gray-900 mb-2">Consultation</h3>
          <p class="text-gray-600 text-sm">Discuss your needs, budget, and timeline</p>
        </div>
        <div>
          <div class="w-16 h-16 bg-brand-100 rounded-full flex items-center justify-center text-2xl font-bold text-brand-700 mx-auto mb-4">2</div>
          <h3 class="font-bold text-gray-900 mb-2">Design & Quote</h3>
          <p class="text-gray-600 text-sm">Custom plans with detailed pricing</p>
        </div>
        <div>
          <div class="w-16 h-16 bg-brand-100 rounded-full flex items-center justify-center text-2xl font-bold text-brand-700 mx-auto mb-4">3</div>
          <h3 class="font-bold text-gray-900 mb-2">Permits & Prep</h3>
          <p class="text-gray-600 text-sm">We handle paperwork and site preparation</p>
        </div>
        <div>
          <div class="w-16 h-16 bg-brand-100 rounded-full flex items-center justify-center text-2xl font-bold text-brand-700 mx-auto mb-4">4</div>
          <h3 class="font-bold text-gray-900 mb-2">Construction</h3>
          <p class="text-gray-600 text-sm">Expert build with quality materials</p>
        </div>
      </div>
    </div>
  </section>
  
  <!-- CTA -->
  <section class="bg-brand-700 text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold mb-4">Ready to Build Your Pole Barn?</h2>
      <p class="text-xl text-brand-100 mb-8 max-w-2xl mx-auto">
        Get a free, no-obligation estimate. We'll discuss your needs and provide a detailed quote.
      </p>
      <a href="/contact" class="btn-primary bg-white text-brand-700 hover:bg-gray-100 text-lg px-8 py-4">
        Request Free Estimate
      </a>
    </div>
  </section>
  
  <Footer />
</Layout>
