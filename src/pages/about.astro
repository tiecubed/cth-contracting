---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const pageTitle = "About Us | CTH Contracting Solutions | Greenville, SC & Anderson, SC Contractor";
const pageDesc = "Learn about CTH Contracting Solutions. 15+ years experience in pole barns, roofing, and construction services across Greenville, SC & Anderson, SC. Licensed & insured contractor.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": "About CTH Contracting Solutions",
  "description": pageDesc,
  "url": "https://cthcontractingsolutions.com/about"
};
---

<Layout title={pageTitle} description={pageDesc} canonical="/about" jsonLd={jsonLd}>
  <Header />
  
  <!-- Hero - Full Screen Style Matching Homepage -->
  <section class="relative min-h-[70vh] flex flex-col items-center justify-center text-center px-4" style="background: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.5)), url('/images/hero-bg.png') center/cover no-repeat;">
    
    <!-- Main Content -->
    <div class="max-w-4xl mx-auto">
      <!-- Small Logo -->
      <div class="mb-6">
        <img src="/images/logo.png" alt="CTH Contracting Solutions" class="w-full max-w-xs mx-auto drop-shadow-2xl opacity-90" />
      </div>
      
      <!-- Title -->
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-white uppercase tracking-wide mb-6 drop-shadow-lg">
        About Us
      </h1>
      
      <!-- Subtitle -->
      <p class="text-xl md:text-2xl text-gold-200 font-medium tracking-wide mb-8 drop-shadow-md max-w-3xl mx-auto">
        Building quality structures and lasting relationships across Greenville, SC & Anderson, SC since 2008.
      </p>
      
      <!-- CTA Button -->
      <div class="flex justify-center">
        <a href="/contact" class="bg-transparent border-2 border-white text-white font-black py-4 px-10 rounded uppercase tracking-wider transition-all duration-300 shadow-lg hover:shadow-2xl hover:-translate-y-1 hover:bg-white hover:text-black">
          Get Estimate
        </a>
      </div>
    </div>
  </section>
  
  <!-- Story Section -->
  <section class="py-20 bg-neutral-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold text-white mb-6">Our Story</h2>
          <div class="prose text-neutral-300 space-y-4">
            <p>
              CTH Contracting Solutions was founded with a simple mission: provide quality construction services 
              with integrity and professionalism. What started as a small team handling local pole barn projects 
              has grown into a full-service contracting company serving homeowners and businesses across Upstate South Carolina.
            </p>
            <p>
              For over 15 years, we've built our reputation one project at a time. We believe in doing things 
              right the first time—using quality materials, following best practices, and standing behind our work.
            </p>
          </div>
        </div>
        <div class="bg-neutral-800 rounded-2xl aspect-[4/3] flex items-center justify-center text-neutral-500 border-4 border-gold-400">
          <span>Company Photo</span>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Values -->
  <section class="py-20 bg-neutral-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-white text-center mb-12">Why We Stand Out</h2>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-neutral-800 p-8 rounded-xl shadow-lg border border-neutral-700">
          <div class="text-4xl mb-4">🎯</div>
          <h3 class="text-xl font-bold text-white mb-2">Quality First</h3>
          <p class="text-neutral-400">We never cut corners. Every project receives the same attention to detail.</p>
        </div>
        <div class="bg-neutral-800 p-8 rounded-xl shadow-lg border border-neutral-700">
          <div class="text-4xl mb-4">🤝</div>
          <h3 class="text-xl font-bold text-white mb-2">Honest Communication</h3>
          <p class="text-neutral-400">Clear timelines, upfront pricing, and regular updates.</p>
        </div>
        <div class="bg-neutral-800 p-8 rounded-xl shadow-lg border border-neutral-700">
          <div class="text-4xl mb-4">🏆</div>
          <h3 class="text-xl font-bold text-white mb-2">Proven Experience</h3>
          <p class="text-neutral-400">15+ years in the industry means we've seen it all.</p>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Stats -->
  <section class="py-20 bg-neutral-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-red-900 rounded-2xl p-8 md:p-12 text-white text-center border-4 border-gold-400">
        <h2 class="text-3xl font-bold mb-4">Licensed, Insured & Experienced</h2>
        <p class="text-xl text-gold-200 mb-8">Your project deserves a contractor you can trust.</p>
        <div class="grid md:grid-cols-4 gap-6">
          <div>
            <div class="text-4xl font-bold text-gold-400 mb-2">15+</div>
            <div class="text-gold-100">Years Experience</div>
          </div>
          <div>
            <div class="text-4xl font-bold text-gold-400 mb-2">500+</div>
            <div class="text-gold-100">Projects Completed</div>
          </div>
          <div>
            <div class="text-4xl font-bold text-gold-400 mb-2">100%</div>
            <div class="text-gold-100">Licensed & Insured</div>
          </div>
          <div>
            <div class="text-4xl font-bold text-gold-400 mb-2">5★</div>
            <div class="text-gold-100">Customer Rating</div>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- CTA -->
  <section class="py-20 bg-red-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-black text-white mb-4 uppercase tracking-wide">Ready to Work With Us?</h2>
      <p class="text-xl text-gold-200 mb-8">Let's discuss your project. Free estimates, no pressure.</p>
      <a href="/contact" class="inline-block bg-orange-600 hover:bg-orange-500 text-white font-black py-4 px-10 rounded transition-all duration-300 uppercase tracking-wider">Get Free Quote</a>
    </div>
  </section>
  
  <Footer />
</Layout>
