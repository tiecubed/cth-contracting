---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const pageTitle = "Page Not Found | CTH Contracting Solutions";
const pageDesc = "The page you are looking for could not be found. Visit our homepage or contact us for assistance.";
---

<Layout title={pageTitle} description={pageDesc}>
  <Header />
  
  <section class="py-24 text-center">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-6xl mb-6">🔍</div>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
        Page Not Found
      </h1>
      <p class="text-xl text-gray-600 mb-8">
        Sorry, the page you're looking for doesn't exist or has been moved.
      </p>
      
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href="/" class="btn-primary">
          Go to Homepage
        </a>
        <a href="/contact" class="btn-secondary">
          Contact Us
        </a>
      </div>
      
      <p class="mt-8 text-gray-500">
        Or call us at 
        <a href="tel:15551234567" class="text-brand-600 font-semibold">(555) 123-4567</a>
      </p>
    </div>
  </section>
  
  <Footer />
</Layout>
