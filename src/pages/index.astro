---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const pageTitle = "CTH Contracting Solutions | Pole Barns, Roofing, Fencing & Grading in Georgia";
const pageDesc = "Professional pole barn construction, roofing, fence building, and land grading services in Georgia. Built right in the country. Free estimates.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "CTH Contracting Solutions",
  "image": "https://cthcontractingsolutions.com/images/logo.png",
  "@id": "https://cthcontractingsolutions.com",
  "url": "https://cthcontractingsolutions.com",
  "telephone": "+15551234567",
  "email": "info@cthcontractingsolutions.com",
  "address": {
    "@type": "PostalAddress",
    "addressRegion": "GA",
    "addressCountry": "US"
  },
  "areaServed": {
    "@type": "State",
    "name": "Georgia"
  },
  "priceRange": "$$",
  "serviceType": ["Pole Barn Construction", "Roofing", "Fence Building", "Land Grading"]
};
---

<Layout title={pageTitle} description={pageDesc} canonical="/" jsonLd={jsonLd}>
  <Header />
  
  <!-- Hero Section - Full Screen with Background -->
  <section class="relative min-h-screen flex flex-col items-center justify-center text-center px-4" style="background: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.4)), url('https://images.unsplash.com/photo-1568605117036-5fe5e7bab0b7?w=1920&q=80') center/cover no-repeat;">
    
    <!-- Top Brand Text -->
    <div class="absolute top-24 left-0 right-0">
      <p class="text-gold-300 text-sm md:text-base tracking-[0.3em] uppercase font-semibold">CTH Contracting Solutions</p>
    </div>
    
    <!-- Main Content -->
    <div class="max-w-4xl mx-auto pt-16">
      <!-- Large Logo -->
      <div class="mb-8">
        <img src="/images/logo.png" alt="CTH Contracting Solutions" class="w-full max-w-md mx-auto drop-shadow-2xl" />
      </div>
      
      <!-- Tagline -->
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white uppercase tracking-wide mb-6 text-shadow-lg">
        Built Right in the Country
      </h1>
      
      <!-- Services -->
      <p class="text-xl md:text-2xl text-gold-400 font-semibold tracking-wide mb-12">
        Pole Barns • Roofing • Fencing • Grading
      </p>
      
      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="bg-orange-600 hover:bg-orange-500 text-white font-bold py-4 px-10 rounded uppercase tracking-wider transition-all duration-300 shadow-lg hover:shadow-xl transform hover:-translate-y-1">
          Get Estimate
        </a>
        <a href="tel:15551234567" class="bg-transparent border-2 border-white text-white font-bold py-4 px-10 rounded uppercase tracking-wider hover:bg-white hover:text-black transition-all duration-300">
          Call Now
        </a>
      </div>
    </div>
    
    <!-- Scroll Indicator -->
    <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce">
      <svg class="w-8 h-8 text-gold-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
      </svg>
    </div>
  </section>
  
  <!-- Services Section -->
  <section class="py-20 bg-neutral-900" id="services">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
          Our Services
        </h2>
        <div class="w-24 h-1 bg-gold-400 mx-auto"></div>
      </div>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="bg-neutral-800 rounded-lg overflow-hidden shadow-xl hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2 border border-neutral-700">
          <div class="h-48 bg-gradient-to-br from-red-800 to-red-900 flex items-center justify-center">
            <span class="text-6xl">🏗️</span>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold text-white mb-2">Pole Barn Building</h3>
            <p class="text-neutral-400 mb-4">Custom post-frame buildings built to last</p>
            <a href="/services/pole-barns" class="text-gold-400 hover:text-gold-300 font-semibold">Learn More →</a>
          </div>
        </div>
        
        <div class="bg-neutral-800 rounded-lg overflow-hidden shadow-xl hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2 border border-neutral-700">
          <div class="h-48 bg-gradient-to-br from-red-800 to-red-900 flex items-center justify-center">
            <span class="text-6xl">🏠</span>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold text-white mb-2">Roofing Services</h3>
            <p class="text-neutral-400 mb-4">Durable metal roofing and repairs</p>
            <a href="/services/roofing" class="text-gold-400 hover:text-gold-300 font-semibold">Learn More →</a>
          </div>
        </div>
        
        <div class="bg-neutral-800 rounded-lg overflow-hidden shadow-xl hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2 border border-neutral-700">
          <div class="h-48 bg-gradient-to-br from-red-800 to-red-900 flex items-center justify-center">
            <span class="text-6xl">🚧</span>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold text-white mb-2">Fence Building</h3>
            <p class="text-neutral-400 mb-4">Secure fencing for any property</p>
            <a href="/services/fences" class="text-gold-400 hover:text-gold-300 font-semibold">Learn More →</a>
          </div>
        </div>
        
        <div class="bg-neutral-800 rounded-lg overflow-hidden shadow-xl hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2 border border-neutral-700">
          <div class="h-48 bg-gradient-to-br from-red-800 to-red-900 flex items-center justify-center">
            <span class="text-6xl">🚜</span>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold text-white mb-2">Land Grading</h3>
            <p class="text-neutral-400 mb-4">Professional site preparation</p>
            <a href="/services/grading" class="text-gold-400 hover:text-gold-300 font-semibold">Learn More →</a>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Why Choose Us -->
  <section class="py-20 bg-neutral-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
            Why Choose CTH Contracting?
          </h2>
          <div class="space-y-6">
            <div class="flex gap-4">
              <div class="flex-shrink-0 w-10 h-10 rounded-full bg-gold-400 flex items-center justify-center text-black font-bold">15+</div>
              <div>
                <h4 class="font-bold text-white text-lg">Years Experience</h4>
                <p class="text-neutral-400">Proven track record of quality craftsmanship</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="flex-shrink-0 w-10 h-10 rounded-full bg-gold-400 flex items-center justify-center text-black font-bold">✓</div>
              <div>
                <h4 class="font-bold text-white text-lg">Licensed & Insured</h4>
                <p class="text-neutral-400">Full coverage for your protection</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="flex-shrink-0 w-10 h-10 rounded-full bg-gold-400 flex items-center justify-center text-black font-bold">GA</div>
              <div>
                <h4 class="font-bold text-white text-lg">Georgia Owned</h4>
                <p class="text-neutral-400">Local contractors you can trust</p>
              </div>
            </div>
          </div>
          <div class="mt-8">
            <a href="/contact" class="inline-block bg-orange-600 hover:bg-orange-500 text-white font-bold py-3 px-8 rounded transition-all duration-300">
              Get Free Quote
            </a>
          </div>
        </div>
        <div class="relative">
          <div class="aspect-square bg-gradient-to-br from-red-900 to-neutral-900 rounded-lg flex items-center justify-center border border-neutral-700">
            <span class="text-neutral-600 text-xl">Project Gallery Coming Soon</span>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- CTA Section -->
  <section class="py-20 bg-red-900 relative overflow-hidden">
    <div class="absolute inset-0 bg-black/20"></div>
    <div class="relative max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
        Ready to Start Your Project?
      </h2>
      <p class="text-xl text-gold-200 mb-8">
        Get a free, no-obligation estimate. We're ready to bring your vision to life.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="bg-gold-400 hover:bg-gold-300 text-black font-bold py-4 px-10 rounded transition-all duration-300">
          Request Free Quote
        </a>
        <a href="tel:15551234567" class="border-2 border-white text-white font-bold py-4 px-10 rounded hover:bg-white hover:text-red-900 transition-all duration-300">
          Call (555) 123-4567
        </a>
      </div>
    </div>
  </section>
  
  <Footer />
</Layout>
