---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const pageTitle = "Roofing Services Greenville SC & Anderson SC | Metal Roofing & Repair";
const pageDesc = "Professional roofing services in Greenville, SC & Anderson, SC. Metal roof installation, roof repair, and replacement. Call (864) 617-1719 for a free estimate.";

const features = [
  "Metal Roofing Installation",
  "Roof Repair & Maintenance",
  "Leak Detection & Repair",
  "Storm Damage Restoration",
  "Energy-Efficient Solutions",
  "Free Estimates & Inspections"
];

const benefits = [
  { icon: "🛡️", title: "Weather Protection", desc: "Metal roofs withstand SC storms" },
  { icon: "💰", title: "Energy Savings", desc: "Reflects heat, lowers cooling costs" },
  { icon: "⏱️", title: "Long Lifespan", desc: "40-70 years with minimal maintenance" },
  { icon: "✅", title: "Hail Resistant", desc: "Won't crack or shatter like shingles" },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Roofing Services",
  "provider": {
    "@type": "LocalBusiness",
    "name": "CTH Contracting Solutions",
    "telephone": "+1-864-617-1719",
    "areaServed": "Greenville, SC; Anderson, SC"
  },
  "serviceType": "Roofing",
  "description": pageDesc
};
---

<Layout title={pageTitle} description={pageDesc} canonical="/services/roofing" jsonLd={jsonLd}>
  <Header />
  
  <!-- Hero -->
  <section class="relative min-h-[70vh] flex flex-col items-center justify-center text-center px-4" style="background: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.5)), url('/images/hero-bg.png') center/cover no-repeat;">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-white uppercase tracking-wide mb-6 drop-shadow-lg">
        Roofing Services
      </h1>
      <p class="text-xl md:text-2xl text-gold-200 font-medium tracking-wide mb-8 drop-shadow-md max-w-3xl mx-auto">
        Durable metal roofing and expert repairs in Greenville, SC & Anderson, SC. Protect your property with quality craftsmanship.
      </p>
      <div class="flex justify-center">
        <a href="/contact" class="bg-transparent border-2 border-white text-white font-black py-4 px-10 rounded uppercase tracking-wider transition-all duration-300 shadow-lg hover:shadow-2xl hover:-translate-y-1 hover:bg-white hover:text-black">
          Get Estimate
        </a>
      </div>
    </div>
  </section>
  
  <!-- Features Grid -->
  <section class="py-20 bg-neutral-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-black text-center text-white mb-12 uppercase tracking-wide">Our Roofing Services</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {features.map(feature => (
          <div class="bg-neutral-800 p-6 rounded-xl border border-neutral-700">
            <div class="text-gold-400 font-bold text-xl mb-2">✓</div>
            <h3 class="text-white font-semibold">{feature}</h3>
          </div>
        ))}
      </div>
    </div>
  </section>
  
  <!-- Benefits -->
  <section class="py-20 bg-neutral-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-black text-center text-white mb-12 uppercase tracking-wide">Why Metal Roofing?</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        {benefits.map(benefit => (
          <div class="bg-neutral-800 p-6 rounded-xl border border-neutral-700 text-center">
            <div class="text-4xl mb-4">{benefit.icon}</div>
            <h3 class="text-white font-bold mb-2">{benefit.title}</h3>
            <p class="text-neutral-400 text-sm">{benefit.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  
  <!-- CTA -->
  <section class="py-20 bg-red-900 border-y-4 border-gold-400">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-black text-white mb-4 uppercase tracking-wide">Need Roof Repair or Replacement?</h2>
      <p class="text-xl text-gold-200 mb-8">Contact us today for a free inspection and estimate.</p>
      <a href="/contact" class="inline-block bg-gold-400 hover:bg-gold-300 text-black font-black py-4 px-10 rounded transition-all duration-300 uppercase tracking-wider shadow-lg hover:shadow-xl hover:-translate-y-1">
        Get Free Quote
      </a>
    </div>
  </section>
  
  <Footer />
</Layout>
