---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const pageTitle = "Roofing Services Greenville SC | Metal Roof Installation | CTH";
const pageDesc = "Professional metal roofing services in Greenville SC & Anderson SC. Standing seam, corrugated metal, reroofing & repairs. Quality materials, expert installation. Free estimates!";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Roofing Services",
  "provider": {
    "@type": "LocalBusiness",
    "name": "CTH Contracting Solutions"
  },
  "areaServed": {
    "@type": "City",
    "name": "Greenville, SC"
  },
  "serviceType": "Roofing Installation",
  "description": pageDesc
};

const features = [
  { title: "Standing Seam", desc: "Premium concealed fastener system", icon: "🏠" },
  { title: "Corrugated Metal", desc: "Classic style, modern durability", icon: "🔩" },
  { title: "Reroofing", desc: "Complete tear-off and replacement", icon: "🔄" },
  { title: "Leak Repairs", desc: "Fast, effective leak solutions", icon: "💧" },
  { title: "Energy Efficient", desc: "Cool roofing technology", icon: "❄️" },
  { title: "40+ Year Warranty", desc: "Long-lasting protection", icon: "🛡️" }
];
---

<Layout title={pageTitle} description={pageDesc} canonical="/services/roofing" jsonLd={jsonLd}>
  <Header />
  
  <!-- Hero -->
  <section class="bg-gradient-to-r from-red-900 to-red-800 text-white py-20 border-b-4 border-gold-400">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-black mb-4 uppercase tracking-wide">Roofing Services</h1>
      <p class="text-xl md:text-2xl text-gold-200 max-w-4xl mx-auto mb-8">
        Durable metal roofing that protects your home for decades. Serving Greenville SC & Anderson SC.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="bg-orange-600 hover:bg-orange-500 text-white font-black py-4 px-10 rounded uppercase tracking-wider transition-all duration-300 shadow-lg hover:shadow-2xl hover:-translate-y-1">
          Free Estimate
        </a>
        <a href="tel:8646171719" class="border-2 border-white text-white font-black py-4 px-10 rounded uppercase tracking-wider hover:bg-white hover:text-black transition-all duration-300">
          Call (864) 617-1719
        </a>
      </div>
    </div>
  </section>
  
  <!-- Features Grid -->
  <section class="py-20 bg-neutral-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-white text-center mb-12">Our Roofing Solutions</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {features.map(feature => (
          <div class="bg-neutral-800 p-6 rounded-xl shadow-lg border border-neutral-700">
            <div class="text-4xl mb-4">{feature.icon}</div>
            <h3 class="text-xl font-bold text-white mb-2">{feature.title}</h3>
            <p class="text-neutral-400">{feature.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  
  <!-- Benefits -->
  <section class="py-20 bg-neutral-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-white text-center mb-12">Why Metal Roofing?</h2>
      <div class="grid md:grid-cols-2 gap-8">
        <div class="bg-neutral-800 p-8 rounded-xl border border-neutral-700">
          <h3 class="text-2xl font-bold text-gold-400 mb-4">Longevity</h3>
          <p class="text-neutral-300">Metal roofs last 40-70 years, compared to 15-20 years for asphalt shingles. It's the last roof you'll ever need.</p>
        </div>
        <div class="bg-neutral-800 p-8 rounded-xl border border-neutral-700">
          <h3 class="text-2xl font-bold text-gold-400 mb-4">Weather Protection</h3>
          <p class="text-neutral-300">Metal roofs withstand high winds, heavy rain, hail, and fire. Perfect for South Carolina's unpredictable weather.</p>
        </div>
      </div>
    </div>
  </section>
  
  <!-- CTA -->
  <section class="py-20 bg-red-900 border-y-4 border-gold-400">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-black text-white mb-4 uppercase tracking-wide">Ready for a New Roof?</h2>
      <p class="text-xl text-gold-200 mb-8">Get a free inspection and estimate. No pressure, just honest advice.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="bg-gold-400 hover:bg-gold-300 text-black font-black py-4 px-10 rounded transition-all duration-300 uppercase tracking-wider shadow-lg hover:shadow-xl hover:-translate-y-1">
          Schedule Free Inspection
        </a>
        <a href="tel:8646171719" class="border-2 border-white text-white font-black py-4 px-10 rounded hover:bg-white hover:text-red-900 transition-all duration-300 uppercase tracking-wider">
          Call Now
        </a>
      </div>
    </div>
  </section>
  
  <Footer />
</Layout>
