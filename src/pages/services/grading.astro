---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const pageTitle = "Land Grading Greenville SC | Site Preparation & Excavation | CTH";
const pageDesc = "Professional land grading and site preparation in Greenville SC & Anderson SC. Excavation, drainage solutions, foundation prep. Quality equipment, experienced operators. Free estimates!";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Land Grading Services",
  "provider": {
    "@type": "LocalBusiness",
    "name": "CTH Contracting Solutions"
  },
  "areaServed": {
    "@type": "City",
    "name": "Greenville, SC"
  },
  "serviceType": "Land Grading",
  "description": pageDesc
};

const services = [
  { title: "Site Leveling", desc: "Precision grading for construction", icon: "📏" },
  { title: "Excavation", desc: "Digging and trenching services", icon: "⛏️" },
  { title: "Drainage Solutions", desc: "Prevent water issues", icon: "💧" },
  { title: "Foundation Prep", desc: "Ready for construction", icon: "🏗️" },
  { title: "Erosion Control", desc: "Protect your landscape", icon: "🌿" },
  { title: "Land Clearing", desc: "Remove obstacles and brush", icon: "🌲" }
];
---

<Layout title={pageTitle} description={pageDesc} canonical="/services/grading" jsonLd={jsonLd}>
  <Header />
  
  <!-- Hero -->
  <section class="bg-gradient-to-r from-red-900 to-red-800 text-white py-20 border-b-4 border-gold-400">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-black mb-4 uppercase tracking-wide">Land Grading</h1>
      <p class="text-xl md:text-2xl text-gold-200 max-w-4xl mx-auto mb-8">
        Professional site preparation and grading. Excavation, drainage solutions & foundation prep.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="bg-orange-600 hover:bg-orange-500 text-white font-black py-4 px-10 rounded uppercase tracking-wider transition-all duration-300 shadow-lg hover:shadow-2xl hover:-translate-y-1">
          Free Estimate
        </a>
        <a href="tel:8646171719" class="border-2 border-white text-white font-black py-4 px-10 rounded uppercase tracking-wider hover:bg-white hover:text-black transition-all duration-300">
          Call (864) 617-1719
        </a>
      </div>
    </div>
  </section>
  
  <!-- Services -->
  <section class="py-20 bg-neutral-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-white text-center mb-12">Our Grading Services</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {services.map(service => (
          <div class="bg-neutral-800 p-6 rounded-xl shadow-lg border border-neutral-700">
            <div class="text-4xl mb-4">{service.icon}</div>
            <h3 class="text-xl font-bold text-white mb-2">{service.title}</h3>
            <p class="text-neutral-400">{service.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  
  <!-- Equipment -->
  <section class="py-20 bg-neutral-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold text-white mb-6">Professional Equipment</h2>
          <ul class="space-y-4 text-neutral-300">
            <li class="flex items-center gap-3">
              <span class="text-gold-400 text-xl">✓</span>
              <span>Skid steer loaders for precision work</span>
            </li>
            <li class="flex items-center gap-3">
              <span class="text-gold-400 text-xl">✓</span>
              <span>Bulldozers for large-scale grading</span>
            </li>
            <li class="flex items-center gap-3">
              <span class="text-gold-400 text-xl">✓</span>
              <span>Excavators for digging and trenching</span>
            </li>
            <li class="flex items-center gap-3">
              <span class="text-gold-400 text-xl">✓</span>
              <span>Dump trucks for material removal</span>
            </li>
          </ul>
        </div>
        <div class="bg-neutral-800 p-8 rounded-xl border border-neutral-700">
          <h3 class="text-2xl font-bold text-gold-400 mb-4">Why Proper Grading Matters</h3>
          <p class="text-neutral-300 mb-4">
            Proper land grading is essential for any construction project. It ensures:
          </p>
          <ul class="space-y-2 text-neutral-400">
            <li>• Proper water drainage</li>
            <li>• Stable foundation for buildings</li>
            <li>• Prevention of erosion</li>
            <li>• Compliance with local codes</li>
          </ul>
        </div>
      </div>
    </div>
  </section>
  
  <!-- CTA -->
  <section class="py-20 bg-red-900 border-y-4 border-gold-400">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-black text-white mb-4 uppercase tracking-wide">Ready to Grade Your Land?</h2>
      <p class="text-xl text-gold-200 mb-8">Free site evaluation and estimate. Quality equipment, experienced operators.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="bg-gold-400 hover:bg-gold-300 text-black font-black py-4 px-10 rounded transition-all duration-300 uppercase tracking-wider shadow-lg hover:shadow-xl hover:-translate-y-1">
          Get Free Quote
        </a>
        <a href="tel:8646171719" class="border-2 border-white text-white font-black py-4 px-10 rounded hover:bg-white hover:text-red-900 transition-all duration-300 uppercase tracking-wider">
          Call Now
        </a>
      </div>
    </div>
  </section>
  
  <Footer />
</Layout>
