---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const pageTitle = "Pole Barn Builders Greenville SC & Anderson SC | Custom Barns";
const pageDesc = "Expert pole barn builders in Greenville, SC & Anderson, SC. Custom post-frame buildings, workshops, garages, and agricultural barns. Free estimates. Call (864) 617-1719.";

const features = [
  {
    title: "Custom Design",
    desc: "Barns built to your exact specifications and needs"
  },
  {
    title: "Quality Materials",
    desc: "Premium lumber, metal roofing, and durable hardware"
  },
  {
    title: "Fast Construction",
    desc: "Post-frame construction is quicker than traditional building"
  },
  {
    title: "Cost Effective",
    desc: "More affordable per square foot than conventional construction"
  },
  {
    title: "Versatile Uses",
    desc: "Agricultural, residential, commercial, or recreational"
  },
  {
    title: "Permit Handling",
    desc: "We help navigate local building codes and permits"
  }
];

const applications = [
  { name: "Agricultural Barns", desc: "Equipment storage, hay barns, livestock shelters" },
  { name: "Workshops", desc: "Personal or commercial workspace" },
  { name: "Garages", desc: "RVs, motorhomes, classic car collections" },
  { name: "Storage Buildings", desc: "Boats, ATVs, seasonal equipment" },
  { name: "Man Caves", desc: "Entertainment spaces, home gyms" },
  { name: "Commercial", desc: "Retail spaces, offices, warehouses" }
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Pole Barn Building",
  "provider": {
    "@type": "LocalBusiness",
    "name": "CTH Contracting Solutions",
    "telephone": "+1-864-617-1719",
    "areaServed": "Greenville, SC; Anderson, SC"
  },
  "serviceType": "Post-Frame Construction",
  "description": pageDesc
};
---

<Layout title={pageTitle} description={pageDesc} canonical="/services/pole-barns" jsonLd={jsonLd}>
  <Header />
  
  <!-- Hero -->
  <section class="relative min-h-[70vh] flex flex-col items-center justify-center text-center px-4" style="background: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.5)), url('/images/hero-bg.png') center/cover no-repeat;">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-white uppercase tracking-wide mb-6 drop-shadow-lg">
        Pole Barn Building
      </h1>
      <p class="text-xl md:text-2xl text-gold-200 font-medium tracking-wide mb-8 drop-shadow-md max-w-3xl mx-auto">
        Custom post-frame construction in Greenville, SC & Anderson, SC. Workshops, barns, garages, and more built to last.
      </p>
      <div class="flex justify-center">
        <a href="/contact" class="bg-transparent border-2 border-white text-white font-black py-4 px-10 rounded uppercase tracking-wider transition-all duration-300 shadow-lg hover:shadow-2xl hover:-translate-y-1 hover:bg-white hover:text-black">
          Get Estimate
        </a>
      </div>
    </div>
  </section>
  
  <!-- Why Pole Barns -->
  <section class="py-20 bg-neutral-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-black text-center text-white mb-12 uppercase tracking-wide">Why Choose a Pole Barn?</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {features.map(feature => (
          <div class="bg-neutral-800 p-6 rounded-xl border border-neutral-700">
            <div class="text-gold-400 text-2xl font-bold mb-3">✓</div>
            <h3 class="text-white font-bold mb-2">{feature.title}</h3>
            <p class="text-neutral-400">{feature.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  
  <!-- Applications -->
  <section class="py-20 bg-neutral-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-black text-center text-white mb-12 uppercase tracking-wide">Pole Barn Applications</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {applications.map(app => (
          <div class="bg-neutral-800 p-6 rounded-xl border border-neutral-700 text-center">
            <h3 class="text-white font-bold mb-2">{app.name}</h3>
            <p class="text-neutral-400 text-sm">{app.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  
  <!-- The CTH Difference -->
  <section class="py-20 bg-neutral-900">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-neutral-800 p-8 rounded-2xl border border-neutral-700">
        <h2 class="text-3xl font-black text-white mb-6 uppercase tracking-wide">The CTH Difference</h2>
        <p class="text-neutral-300 text-lg leading-relaxed mb-6">
          At CTH Contracting Solutions, we've built hundreds of pole barns across Upstate South Carolina. We understand the local climate, soil conditions, and building requirements.
        </p>
        <p class="text-neutral-300 text-lg leading-relaxed mb-6">
          Our team handles everything from permits to final inspection, ensuring your barn is built right and built to last. We use only quality materials and proven construction techniques.
        </p>
        <ul class="grid md:grid-cols-2 gap-4">
          <li class="flex items-center gap-3 text-neutral-300">
            <span class="text-gold-400 text-xl">✓</span> Licensed & Insured
          </li>
          <li class="flex items-center gap-3 text-neutral-300">
            <span class="text-gold-400 text-xl">✓</span> 15+ Years Experience
          </li>
          <li class="flex items-center gap-3 text-neutral-300">
            <span class="text-gold-400 text-xl">✓</span> Free Estimates
          </li>
          <li class="flex items-center gap-3 text-neutral-300">
            <span class="text-gold-400 text-xl">✓</span> Local Experts
          </li>
        </ul>
      </div>
    </div>
  </section>
  
  <!-- CTA -->
  <section class="py-20 py-20 bg-red-900 border-y-4 border-gold-400">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-black text-white mb-4 uppercase tracking-wide">Ready to Build Your Pole Barn?</h2>
      <p class="text-xl text-gold-200 mb-8">Contact us for a free consultation and detailed estimate.</p>
      <a href="/contact" class="inline-block bg-gold-400 hover:bg-gold-300 text-black font-black py-4 px-10 rounded transition-all duration-300 uppercase tracking-wider shadow-lg hover:shadow-xl hover:-translate-y-1">
        Get Free Quote
      </a>
    </div>
  </section>
  
  <Footer />
</Layout>
