---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const pageTitle = "Land Grading Greenville SC & Anderson SC | Site Preparation & Excavation";
const pageDesc = "Professional land grading and site preparation in Greenville, SC & Anderson, SC. Excavation, drainage solutions, and foundation prep. Free estimates. Call (864) 617-1719.";

const services = [
  {
    title: "Site Leveling",
    desc: "Proper grading for construction projects of all sizes",
    icon: "📐"
  },
  {
    title: "Excavation",
    desc: "Digging and earth removal for foundations and utilities",
    icon: "⛏️"
  },
  {
    title: "Drainage Solutions",
    desc: "French drains, swales, and grading to prevent water issues",
    icon: "💧"
  },
  {
    title: "Foundation Prep",
    desc: "Properly graded and compacted base for building foundations",
    icon: "🏗️"
  },
  {
    title: "Erosion Control",
    desc: "Solutions to prevent soil erosion and runoff problems",
    icon: "🌱"
  },
  {
    title: "Driveway Prep",
    desc: "Grading for gravel and paved driveways",
    icon: "🚜"
  }
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Land Grading Services",
  "provider": {
    "@type": "LocalBusiness",
    "name": "CTH Contracting Solutions",
    "telephone": "+1-864-617-1719",
    "areaServed": "Greenville, SC; Anderson, SC"
  },
  "serviceType": "Land Grading",
  "description": pageDesc
};
---

<Layout title={pageTitle} description={pageDesc} canonical="/services/grading" jsonLd={jsonLd}>
  <Header />
  
  <!-- Hero -->
  <section class="relative min-h-[70vh] flex flex-col items-center justify-center text-center px-4" style="background: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.5)), url('/images/hero-bg.png') center/cover no-repeat;">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-white uppercase tracking-wide mb-6 drop-shadow-lg">
        Land Grading
      </h1>
      <p class="text-xl md:text-2xl text-gold-200 font-medium tracking-wide mb-8 drop-shadow-md max-w-3xl mx-auto">
        Professional site preparation and grading in Greenville, SC & Anderson, SC. Excavation, drainage, and foundation prep for any project.
      </p>
      <div class="flex justify-center">
        <a href="/contact" class="bg-transparent border-2 border-white text-white font-black py-4 px-10 rounded uppercase tracking-wider transition-all duration-300 shadow-lg hover:shadow-2xl hover:-translate-y-1 hover:bg-white hover:text-black">
          Get Estimate
        </a>
      </div>
    </div>
  </section>
  
  <!-- Services Grid -->
  <section class="py-20 bg-neutral-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-black text-center text-white mb-12 uppercase tracking-wide">Grading Services</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {services.map(service => (
          <div class="bg-neutral-800 p-8 rounded-2xl border border-neutral-700 text-center">
            <div class="text-5xl mb-4">{service.icon}</div>
            <h3 class="text-xl font-bold text-white mb-3">{service.title}</h3>
            <p class="text-neutral-400">{service.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  
  <!-- Why Proper Grading -->
  <section class="py-20 bg-neutral-950">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-black text-center text-white mb-8 uppercase tracking-wide">Why Proper Grading Matters</h2>
      <div class="bg-neutral-800 p-8 rounded-2xl border border-neutral-700">
        <p class="text-neutral-300 text-lg leading-relaxed mb-6">
          Proper land grading is the foundation of any successful construction project. Without correct grading, you risk water damage, foundation issues, and drainage problems that can cost thousands to fix later.
        </p>
        <p class="text-neutral-300 text-lg leading-relaxed mb-6">
          At CTH Contracting Solutions, we understand the unique soil and topography challenges of Upstate South Carolina. Our experienced crew ensures your site is properly prepared for whatever you're building.
        </p>
        <ul class="space-y-3">
          <li class="flex items-start gap-3 text-neutral-300">
            <span class="text-gold-400 text-xl">✓</span>
            <span>Prevents water from pooling near foundations</span>
          </li>
          <li class="flex items-start gap-3 text-neutral-300">
            <span class="text-gold-400 text-xl">✓</span>
            <span>Creates stable base for construction</span>
          </li>
          <li class="flex items-start gap-3 text-neutral-300">
            <span class="text-gold-400 text-xl">✓</span>
            <span>Directs runoff away from structures</span>
          </li>
          <li class="flex items-start gap-3 text-neutral-300">
            <span class="text-gold-400 text-xl">✓</span>
            <span>Complies with local building codes</span>
          </li>
        </ul>
      </div>
    </div>
  </section>
  
  <!-- CTA -->
  <section class="py-20 bg-red-900 border-y-4 border-gold-400">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-black text-white mb-4 uppercase tracking-wide">Need Site Preparation?</h2>
      <p class="text-xl text-gold-200 mb-8">Contact us for a free site evaluation and estimate.</p>
      <a href="/contact" class="inline-block bg-gold-400 hover:bg-gold-300 text-black font-black py-4 px-10 rounded transition-all duration-300 uppercase tracking-wider shadow-lg hover:shadow-xl hover:-translate-y-1">
        Get Free Quote
      </a>
    </div>
  </section>
  
  <Footer />
</Layout>
