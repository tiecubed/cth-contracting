---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const pageTitle = "Contact Us | Free Estimates | CTH Contracting Solutions";
const pageDesc = "Get a free estimate for pole barns, metal roofing, fencing, and construction services in Georgia. Call (555) 123-4567 or fill out our contact form.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Contact CTH Contracting Solutions",
  "description": pageDesc,
  "url": "https://cthcontractingsolutions.com/contact",
  "mainEntity": {
    "@type": "LocalBusiness",
    "name": "CTH Contracting Solutions",
    "telephone": "+15551234567",
    "email": "info@cthcontractingsolutions.com",
    "areaServed": {
      "@type": "State",
      "name": "Georgia"
    }
  }
};
---

<Layout title={pageTitle} description={pageDesc} canonical="/contact" jsonLd={jsonLd}>
  <Header />
  
  <!-- Hero -->
  <section class="bg-gradient-to-r from-brand-800 to-brand-600 text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Get Your Free Estimate</h1>
      <p class="text-xl text-brand-100 max-w-3xl mx-auto">
        Ready to start your project? Contact us today for a free, no-obligation quote. 
        We typically respond within 24 hours.
      </p>
    </div>
  </section>
  
  <!-- Contact Section -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12">
        <!-- Contact Info -->
        <div>
          <h2 class="text-3xl font-bold text-gray-900 mb-6">Contact Information</h2>
          <p class="text-gray-600 mb-8">
            Prefer to reach us directly? We're here to answer your questions and discuss your project needs.
          </p>
          
          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-12 h-12 bg-brand-100 rounded-lg flex items-center justify-center text-2xl">
                📞
              </div>
              <div>
                <h3 class="font-semibold text-gray-900">Phone</h3>
                <p class="text-gray-600 mb-1">Call us anytime during business hours</p>
                <a href="tel:15551234567" class="text-brand-600 font-semibold text-lg hover:underline">
                  (555) 123-4567
                </a>
              </div>
            </div>
            
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-12 h-12 bg-brand-100 rounded-lg flex items-center justify-center text-2xl">
                ✉️
              </div>
              <div>
                <h3 class="font-semibold text-gray-900">Email</h3>
                <p class="text-gray-600 mb-1">We'll respond within 24 hours</p>
                <a href="mailto:info@cthcontractingsolutions.com" class="text-brand-600 font-semibold hover:underline">
                  info@cthcontractingsolutions.com
                </a>
              </div>
            </div>
            
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-12 h-12 bg-brand-100 rounded-lg flex items-center justify-center text-2xl">
                🕐
              </div>
              <div>
                <h3 class="font-semibold text-gray-900">Business Hours</h3>
                <p class="text-gray-600">
                  Monday - Friday: 7:00 AM - 6:00 PM<br>
                  Saturday: 8:00 AM - 2:00 PM<br>
                  Sunday: Closed
                </p>
              </div>
            </div>
            
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-12 h-12 bg-brand-100 rounded-lg flex items-center justify-center text-2xl">
                📍
              </div>
              <div>
                <h3 class="font-semibold text-gray-900">Service Area</h3>
                <p class="text-gray-600">
                  Serving all of Georgia<br>
                  Based in Central Georgia
                </p>
              </div>
            </div>
          </div>
          
          <!-- Emergency Note -->
          <div class="mt-8 p-4 bg-yellow-50 border border-yellow-200 rounded-lg">
            <p class="text-sm text-yellow-800">
              <strong>Storm damage or urgent repair?</strong> Call us directly at (555) 123-4567 for emergency service.
            </p>
          </div>
        </div>
        
        <!-- Contact Form -->
        <div class="bg-white p-8 rounded-2xl shadow-lg border border-gray-100">
          <h2 class="text-2xl font-bold text-gray-900 mb-2">Request a Quote</h2>
          <p class="text-gray-600 mb-6">Tell us about your project and we'll get back to you shortly.</p>
          
          <form name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/thank-you" class="space-y-4">
            <!-- Netlify form requirements -->
            <input type="hidden" name="form-name" value="contact" />
            <p class="hidden">
              <label>Don't fill this out: <input name="bot-field" /></label>
            </p>
            
            <div class="grid md:grid-cols-2 gap-4">
              <div>
                <label for="firstName" class="block text-sm font-medium text-gray-700 mb-1">First Name *</label>
                <input type="text" id="firstName" name="firstName" required
                  class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none transition-colors" />
              </div>
              <div>
                <label for="lastName" class="block text-sm font-medium text-gray-700 mb-1">Last Name *</label>
                <input type="text" id="lastName" name="lastName" required
                  class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none transition-colors" />
              </div>
            </div>
            
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email Address *</label>
              <input type="email" id="email" name="email" required
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none transition-colors" />
            </div>
            
            <div>
              <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">Phone Number *</label>
              <input type="tel" id="phone" name="phone" required
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none transition-colors" />
            </div>
            
            <div>
              <label for="service" class="block text-sm font-medium text-gray-700 mb-1">Service Interested In *</label>
              <select id="service" name="service" required
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none transition-colors">
                <option value="">Select a service...</option>
                <option value="pole-barn">Pole Barn Building</option>
                <option value="metal-roof">Metal Roof Replacement</option>
                <option value="fence">Fence Building</option>
                <option value="truss-repair">Truss Repair</option>
                <option value="general">General Contracting</option>
                <option value="other">Other / Not Sure</option>
              </select>
            </div>
            
            <div>
              <label for="location" class="block text-sm font-medium text-gray-700 mb-1">Project Location (City/County) *</label>
              <input type="text" id="location" name="location" required placeholder="e.g., Macon, GA"
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none transition-colors" />
            </div>
            
            <div>
              <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Tell Us About Your Project *</label>
              <textarea id="message" name="message" rows="4" required placeholder="Size of building, timeline, specific requirements..."
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none transition-colors resize-y"></textarea>
            </div>
            
            <div>
              <label class="flex items-start gap-3">
                <input type="checkbox" name="consent" required
                  class="mt-1 w-4 h-4 text-brand-600 border-gray-300 rounded focus:ring-brand-500" />
                <span class="text-sm text-gray-600">
                  I agree to be contacted about my project. Your information is never shared with third parties.
                </span>
              </label>
            </div>
            
            <button type="submit" class="w-full btn-primary text-lg py-3 justify-center">
              Send Request
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>
  
  <Footer />
</Layout>
