---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const pageTitle = "Get a Free Quote | CTH Contracting Solutions | Greenville, SC & Anderson, SC";
const pageDesc = "Contact CTH Contracting Solutions for a free estimate on pole barns, roofing, fencing, and grading. Serving Greenville, SC & Anderson, SC. Call (864) 617-1719.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Contact CTH Contracting Solutions",
  "description": pageDesc,
  "url": "https://cthcontractingsolutions.com/contact",
  "mainEntity": {
    "@type": "LocalBusiness",
    "name": "CTH Contracting Solutions",
    "telephone": "+1-864-617-1719",
    "email": "cthcontractingolutions@gmail.com",
    "areaServed": "Greenville, SC; Anderson, SC; Upstate South Carolina",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Greenville",
      "addressRegion": "SC",
      "addressCountry": "US"
    }
  }
};
---

<Layout title={pageTitle} description={pageDesc} canonical="/contact" jsonLd={jsonLd}>
  <Header />
  
  <!-- Hero -->
  <section class="relative min-h-[70vh] flex flex-col items-center justify-center text-center px-4" style="background: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.5)), url('/images/hero-bg.png') center/cover no-repeat;">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-white uppercase tracking-wide mb-6 drop-shadow-lg">
        Get Your Free Quote
      </h1>
      <p class="text-xl md:text-2xl text-gold-200 font-medium tracking-wide mb-8 drop-shadow-md max-w-3xl mx-auto">
        Ready to start your project? Tell us what you need and we'll get back to you within 24 hours with a detailed estimate.
      </p>
      <div class="flex justify-center">
        <a href="tel:8646171719" class="bg-transparent border-2 border-white text-white font-black py-4 px-10 rounded uppercase tracking-wider transition-all duration-300 shadow-lg hover:shadow-2xl hover:-translate-y-1 hover:bg-white hover:text-black">
          Call Now
        </a>
      </div>
    </div>
  </section>
  
  <!-- Contact Form Section -->
  <section class="py-20 bg-neutral-900">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Form Card -->
      <div class="bg-neutral-800 rounded-2xl p-8 border border-neutral-700 shadow-xl">
        <div class="text-center mb-8">
          <h2 class="text-2xl font-bold text-white mb-2">Request a Call Back</h2>
          <p class="text-neutral-400">Enter your info and we'll contact you within 24 hours.</p>
        </div>
        
        <form name="contact" method="POST" data-netlify="true" action="/thank-you" class="space-y-6">
          <input type="hidden" name="form-name" value="contact" />
          
          <div>
            <label for="name" class="block text-white font-semibold mb-2">Your Name</label>
            <input type="text" name="name" id="name" required
                   class="w-full px-4 py-3 rounded bg-neutral-700 border border-neutral-600 text-white placeholder-neutral-500 focus:outline-none focus:border-gold-400 focus:ring-1 focus:ring-gold-400 transition-colors"
                   placeholder="Enter your name" />
          </div>
          
          <div>
            <label for="phone" class="block text-white font-semibold mb-2">Phone Number</label>
            <input type="tel" name="phone" id="phone" required
                   class="w-full px-4 py-3 rounded bg-neutral-700 border border-neutral-600 text-white placeholder-neutral-500 focus:outline-none focus:border-gold-400 focus:ring-1 focus:ring-gold-400 transition-colors"
                   placeholder="Enter your phone number" />
          </div>
          
          <button type="submit" 
                  class="w-full bg-gold-400 hover:bg-gold-300 text-black font-black py-4 rounded transition-all duration-300 uppercase tracking-wider shadow-lg hover:shadow-xl hover:-translate-y-1">
            Request Call Back
          </button>
        </form>
        
        <!-- Alternative Contact -->
        <div class="mt-8 pt-8 border-t border-neutral-700 text-center">
          <p class="text-neutral-400 mb-2">Or you can call or text us now</p>
          <a href="tel:8646171719" class="text-2xl font-black text-gold-400 hover:text-gold-300 transition-colors">
            (864) 617-1719
          </a>
          <p class="text-neutral-500 text-sm mt-2">We typically respond within minutes during business hours</p>
        </div>
      </div>
      
    </div>
  </section>
  
  <!-- Quick Info -->
  <section class="py-20 bg-neutral-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-neutral-800 p-6 rounded-xl border border-neutral-700 text-center">
          <div class="text-3xl mb-3">📞</div>
          <h3 class="text-white font-bold mb-2">Call or Text</h3>
          <a href="tel:8646171719" class="text-gold-400 hover:text-gold-300 text-lg">(864) 617-1719</a>
        </div>
        <div class="bg-neutral-800 p-6 rounded-xl border border-neutral-700 text-center">
          <div class="text-3xl mb-3">📧</div>
          <h3 class="text-white font-bold mb-2">Email</h3>
          <a href="mailto:cthcontractingolutions@gmail.com" class="text-gold-400 hover:text-gold-300">cthcontractingolutions@gmail.com</a>
        </div>
        <div class="bg-neutral-800 p-6 rounded-xl border border-neutral-700 text-center">
          <div class="text-3xl mb-3">📍</div>
          <h3 class="text-white font-bold mb-2">Service Area</h3>
          <p class="text-neutral-400">Greenville, SC & Anderson, SC</p>
        </div>
      </div>
    </div>
  </section>
  
  <Footer />
</Layout>
