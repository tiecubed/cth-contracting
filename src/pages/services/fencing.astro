---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const pageTitle = "Fence Building Greenville SC & Anderson SC | Wood, Vinyl & Chain Link";
const pageDesc = "Professional fence installation in Greenville, SC & Anderson, SC. Wood privacy fences, vinyl, chain link, and farm fencing. Free estimates. Call (864) 617-1719.";

const fenceTypes = [
  {
    type: "Wood Privacy Fences",
    description: "Traditional wood fences for privacy and security",
    features: ["6ft height options", "Pressure-treated lumber", "Custom designs", "Gates included"]
  },
  {
    type: "Vinyl Fencing",
    description: "Low-maintenance, long-lasting vinyl options",
    features: ["Never needs painting", "Resists weathering", "Multiple colors", "Easy to clean"]
  },
  {
    type: "Chain Link",
    description: "Affordable security for residential and commercial",
    features: ["Galvanized steel", "Various heights", "Quick installation", "Low maintenance"]
  },
  {
    type: "Farm & Ranch Fencing",
    description: "Durable fencing for agricultural properties",
    features: ["Barbed wire", "Field fencing", "Board fencing", "Gates & hardware"]
  }
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Fence Building",
  "provider": {
    "@type": "LocalBusiness",
    "name": "CTH Contracting Solutions",
    "telephone": "+1-864-617-1719",
    "areaServed": "Greenville, SC; Anderson, SC"
  },
  "serviceType": "Fence Installation",
  "description": pageDesc
};
---

<Layout title={pageTitle} description={pageDesc} canonical="/services/fencing" jsonLd={jsonLd}>
  <Header />
  
  <!-- Hero -->
  <section class="relative min-h-[70vh] flex flex-col items-center justify-center text-center px-4" style="background: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.5)), url('/images/hero-bg.png') center/cover no-repeat;">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-white uppercase tracking-wide mb-6 drop-shadow-lg">
        Fence Building
      </h1>
      <p class="text-xl md:text-2xl text-gold-200 font-medium tracking-wide mb-8 drop-shadow-md max-w-3xl mx-auto">
        Professional fence installation in Greenville, SC & Anderson, SC. Wood, vinyl, chain link, and farm fencing for any property.
      </p>
      <div class="flex justify-center">
        <a href="/contact" class="bg-transparent border-2 border-white text-white font-black py-4 px-10 rounded uppercase tracking-wider transition-all duration-300 shadow-lg hover:shadow-2xl hover:-translate-y-1 hover:bg-white hover:text-black">
          Get Estimate
        </a>
      </div>
    </div>
  </section>
  
  <!-- Fence Types -->
  <section class="py-20 bg-neutral-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-black text-center text-white mb-12 uppercase tracking-wide">Fence Options</h2>
      <div class="grid md:grid-cols-2 gap-8">
        {fenceTypes.map(fence => (
          <div class="bg-neutral-800 rounded-2xl p-8 border border-neutral-700">
            <h3 class="text-2xl font-bold text-white mb-3">{fence.type}</h3>
            <p class="text-neutral-400 mb-6">{fence.description}</p>
            <ul class="space-y-2">
              {fence.features.map(feature => (
                <li class="flex items-center gap-2 text-neutral-300">
                  <span class="text-gold-400">✓</span> {feature}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>
  
  <!-- Process -->
  <section class="py-20 bg-neutral-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-black text-center text-white mb-12 uppercase tracking-wide">Our Process</h2>
      <div class="grid md:grid-cols-4 gap-6">
        <div class="bg-neutral-800 p-6 rounded-xl border border-neutral-700 text-center">
          <div class="text-4xl mb-4">1</div>
          <h3 class="text-white font-bold mb-2">Free Consultation</h3>
          <p class="text-neutral-400 text-sm">We visit your property and discuss your needs</p>
        </div>
        <div class="bg-neutral-800 p-6 rounded-xl border border-neutral-700 text-center">
          <div class="text-4xl mb-4">2</div>
          <h3 class="text-white font-bold mb-2">Custom Quote</h3>
          <p class="text-neutral-400 text-sm">Detailed estimate with no hidden costs</p>
        </div>
        <div class="bg-neutral-800 p-6 rounded-xl border border-neutral-700 text-center">
          <div class="text-4xl mb-4">3</div>
          <h3 class="text-white font-bold mb-2">Installation</h3>
          <p class="text-neutral-400 text-sm">Professional crew completes the job efficiently</p>
        </div>
        <div class="bg-neutral-800 p-6 rounded-xl border border-neutral-700 text-center">
          <div class="text-4xl mb-4">4</div>
          <h3 class="text-white font-bold mb-2">Final Walkthrough</h3>
          <p class="text-neutral-400 text-sm">We ensure you're 100% satisfied</p>
        </div>
      </div>
    </div>
  </section>
  
  <!-- CTA -->
  <section class="py-20 py-20 bg-red-900 border-y-4 border-gold-400">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-black text-white mb-4 uppercase tracking-wide">Ready for Your New Fence?</h2>
      <p class="text-xl text-gold-200 mb-8">Contact us today for a free on-site estimate.</p>
      <a href="/contact" class="inline-block bg-gold-400 hover:bg-gold-300 text-black font-black py-4 px-10 rounded transition-all duration-300 uppercase tracking-wider shadow-lg hover:shadow-xl hover:-translate-y-1">
        Get Free Quote
      </a>
    </div>
  </section>
  
  <Footer />
</Layout>
