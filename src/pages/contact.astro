---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const pageTitle = "Contact Us | Free Estimates | CTH Contracting Solutions";
const pageDesc = "Get a free estimate for pole barns, roofing, fencing, and grading services in Georgia. Call (555) 123-4567 or fill out our contact form.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Contact CTH Contracting Solutions",
  "description": pageDesc,
  "url": "https://cthcontractingsolutions.com/contact"
};
---

<Layout title={pageTitle} description={pageDesc} canonical="/contact" jsonLd={jsonLd}>
  <Header />
  
  <!-- Hero -->
  <section class="bg-gradient-to-r from-red-800 to-red-700 text-white py-16 border-b-4 border-gold-400">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Get Your Free Estimate</h1>
      <p class="text-xl text-gold-100 max-w-3xl mx-auto">
        Ready to start your project? Contact us today for a free, no-obligation quote.
      </p>
    </div>
  </section>
  
  <!-- Contact Section -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12">
        <!-- Contact Info -->
        <div>
          <h2 class="text-3xl font-bold text-red-900 mb-6">Contact Information</h2>
          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-12 h-12 bg-red-100 rounded-lg flex items-center justify-center text-2xl">📞</div>
              <div>
                <h3 class="font-semibold text-red-900">Phone</h3>
                <a href="tel:15551234567" class="text-red-700 font-bold text-lg hover:underline">(555) 123-4567</a>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-12 h-12 bg-red-100 rounded-lg flex items-center justify-center text-2xl">✉️</div>
              <div>
                <h3 class="font-semibold text-red-900">Email</h3>
                <a href="mailto:info@cthcontractingsolutions.com" class="text-red-700 hover:underline">info@cthcontractingsolutions.com</a>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-12 h-12 bg-red-100 rounded-lg flex items-center justify-center text-2xl">🕐</div>
              <div>
                <h3 class="font-semibold text-red-900">Business Hours</h3>
                <p class="text-red-800">Mon-Fri: 7AM-6PM<br>Sat: 8AM-2PM<br>Sun: Closed</p>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Contact Form -->
        <div class="bg-gold-50 p-8 rounded-2xl shadow-lg border-2 border-gold-200">
          <h2 class="text-2xl font-bold text-red-900 mb-2">Request a Quote</h2>
          <form name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/thank-you" class="space-y-4">
            <input type="hidden" name="form-name" value="contact" />
            <p class="hidden"><label>Don't fill this out: <input name="bot-field" /></label></p>
            
            <div class="grid md:grid-cols-2 gap-4">
              <div>
                <label for="firstName" class="block text-sm font-medium text-red-900 mb-1">First Name *</label>
                <input type="text" id="firstName" name="firstName" required
                  class="w-full px-4 py-2 border border-gold-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-red-500 outline-none" />
              </div>
              <div>
                <label for="lastName" class="block text-sm font-medium text-red-900 mb-1">Last Name *</label>
                <input type="text" id="lastName" name="lastName" required
                  class="w-full px-4 py-2 border border-gold-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-red-500 outline-none" />
              </div>
            </div>
            
            <div>
              <label for="email" class="block text-sm font-medium text-red-900 mb-1">Email *</label>
              <input type="email" id="email" name="email" required
                class="w-full px-4 py-2 border border-gold-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-red-500 outline-none" />
            </div>
            
            <div>
              <label for="phone" class="block text-sm font-medium text-red-900 mb-1">Phone *</label>
              <input type="tel" id="phone" name="phone" required
                class="w-full px-4 py-2 border border-gold-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-red-500 outline-none" />
            </div>
            
            <div>
              <label for="service" class="block text-sm font-medium text-red-900 mb-1">Service *</label>
              <select id="service" name="service" required
                class="w-full px-4 py-2 border border-gold-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-red-500 outline-none">
                <option value="">Select a service...</option>
                <option value="pole-barn">Pole Barn Building</option>
                <option value="roofing">Roofing Services</option>
                <option value="fence">Fence Building</option>
                <option value="grading">Land Grading</option>
              </select>
            </div>
            
            <div>
              <label for="message" class="block text-sm font-medium text-red-900 mb-1">Project Details *</label>
              <textarea id="message" name="message" rows="4" required
                class="w-full px-4 py-2 border border-gold-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-red-500 outline-none resize-y"></textarea>
            </div>
            
            <button type="submit" class="w-full btn-primary text-lg py-3">
              Send Request
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>
  
  <Footer />
</Layout>
